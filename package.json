{
  "name": "z-code-visualizer",
  "displayName": "CodeMap Visualizer",
  "publisher": "taruntrk",
  "description": "Visualize your entire codebase as an interactive map — files, folders, imports, function calls, CSS, environment variables, and database connections.",
  "version": "0.0.2",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.115.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/taruntrk/codemap-visualizer.git"
  },
  "keywords": [
    "codebase",
    "visualizer",
    "graph",
    "dependency",
    "map",
    "imports"
  ],
  "activationEvents": [
    "onCommand:codemap-visualizer.generate",
    "onCommand:codemap-visualizer.generateForFolder"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codemap-visualizer.generate",
        "title": "Generate Codebase Map"
      },
      {
        "command": "codemap-visualizer.generateForFolder",
        "title": "Generate CodeMap for this Folder"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "codemap-visualizer.generateForFolder",
          "when": "explorerResourceIsFolder",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "24.x",
    "@types/vscode": "^1.115.0",
    "@vscode/test-cli": "^0.0.15",
    "@vscode/test-electron": "^3.0.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "npm-run-all": "^4.1.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1"
  },
  "overrides": {
    "diff": "^8.0.4",
    "serialize-javascript": "^7.0.6"
  },
  "dependencies": {
    "tree-sitter-python": "^0.25.0",
    "web-tree-sitter": "^0.26.10"
  }
}
